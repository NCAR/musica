{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["javascript/**/*.js"],
  "exclude": [
    "javascript/**/*.d.ts",
    "javascript/tests",
    "javascript/wasm",
    "javascript/tools"
  ]
}
