prefix=/usr/local
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

yaml_lib=yaml-cpp
#yaml_lib=yaml-cppd

Name: musica
Description: MUSICA library for modeling atmospheric chemistry
Version: 0.15.0
Cflags: -I${includedir}
Libs: -L${libdir} -lmusica -lmechanism_configuration -l${yaml_lib}
