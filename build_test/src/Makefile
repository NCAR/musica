util.cpp.i:
	cd /home/runner/work/musica/musica/build_test && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/musica.dir/build.make src/CMakeFiles/musica.dir/util.cpp.i
.PHONY : util.cpp.i

util.s: util.cpp.s
.PHONY : util.s

# target to generate assembly for a file
util.cpp.s:
	cd /home/runner/work/musica/musica/build_test && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/musica.dir/build.make src/CMakeFiles/musica.dir/util.cpp.s
.PHONY : util.cpp.s

