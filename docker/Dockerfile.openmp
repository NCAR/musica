FROM fedora:41

ARG BUILD_TYPE=Debug

RUN dnf -y update \
    && dnf -y install \
        cmake \
        curl \
        gcc \
        gcc-c++ \
        git \
        hdf5-devel \
        lapack-devel \
        libcurl-devel \
        m4 \
        make \
        netcdf-fortran-devel \
        valgrind \
        zlib-devel \
    && dnf clean all

ENV OMP_NUM_THREADS=3

COPY . musica

RUN cd musica \
    && cmake -S . \
             -B build \
             -D CMAKE_BUILD_TYPE=${BUILD_TYPE} \
             -D MUSICA_ENABLE_OPENMP=ON \
             -D MUSICA_ENABLE_TESTS=ON \
    && cd build \
    && make -j$(nproc) \
    && make install

WORKDIR /musica/build
